{
  "name": "AIM",
  "version": "1.0.0",
  "private": true,
  "description": "AIM Desktop - Electron application for AI prompt management",
  "main": "dist/main/index.js",
  "bin": {
    "aim": "bin/aim.cjs"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "pnpm --filter @momo/server run build && pnpm --filter @momo/file-editor run build && vite",
    "dev:web": "vite --config vite.web.config.ts",
    "electron:build:linux": "pnpm --filter @momo/file-editor run build && vite build && electron-builder --linux --x64 --publish never",
    "electron:build:mac": "pnpm --filter @momo/file-editor run build && vite build && electron-builder --mac --x64 --arm64 --publish never",
    "electron:build:win": "pnpm --filter @momo/file-editor run build && vite build && electron-builder --win --x64 --publish never",
    "electron:dev": "pnpm --filter @momo/server run build && pnpm --filter @momo/electron run build && pnpm --filter @momo/file-editor run build && vite",
    "perf:budget": "node --experimental-strip-types scripts/check-large-data-budgets.mts",
    "perf:budget:ci": "node --experimental-strip-types scripts/profile-large-datasets.mts --prompts=5000 --skills=2000 --iterations=20",
    "perf:large-data": "node --experimental-strip-types scripts/profile-large-datasets.mts",
    "perf:large-data:heavy": "node --experimental-strip-types scripts/profile-large-datasets.mts --prompts=5000 --skills=2000 --iterations=20",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@log4js-node/smtp": "^1.1.0",
    "@momo/aichat": "workspace:*",
    "@momo/electron": "workspace:*",
    "@momo/file-editor": "workspace:*",
    "@momo/knowledge": "workspace:*",
    "@momo/langchain": "workspace:*",
    "@momo/markdown": "workspace:*",
    "@momo/server": "workspace:*",
    "@momo/tree": "workspace:*",
    "@momo/utils": "workspace:*",
    "@momo/workflow": "workspace:*",
    "@napi-rs/canvas": "^0.1.80",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.3.7",
    "better-sqlite3": "12.9.0",
    "docx": "^9.7.0",
    "giget": "^3.2.0",
    "html-to-docx": "^1.8.0",
    "log4js": "^6.3.0",
    "mammoth": "^1.6.0",
    "markdown-it": "^14.1.1",
    "markdown-it-mermaid": "^0.2.5",
    "mermaid": "^11.14.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron": "39.8.2",
    "electron-builder": "26.9.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.26.1",
    "highlight.js": "^11.8.0",
    "jsdom": "^27.3.0",
    "less": "^4.4.1",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vite": "^7.1.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "zustand": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
