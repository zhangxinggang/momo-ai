{
  "name": "@momo/markdown",
  "version": "6.5.0",
  "description": "Markdown editor for react, developed in jsx and typescript, dark theme、beautify content by prettier、render articles directly、paste or clip the picture and upload it...",
  "keywords": [
    "react",
    "nextjs",
    "javascript",
    "typescript",
    "jsx",
    "tsx",
    "ssr",
    "markdown",
    "editor",
    "theme",
    "html"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/es/index.mjs",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./lib/cjs/index.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsx ./scripts/build",
    "dev": "tsx ./scripts/dev",
    "lint": "eslint --ext .ts,.tsx,.vue --fix src",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.7",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@lezer/highlight": "^1.2.1",
    "@mermaid-js/mermaid-zenuml": "0.2.3",
    "@momo/utils": "workspace:*",
    "@types/markdown-it": "^14.0.1",
    "@vavt/cm-extension": "^1.11.2",
    "@vavt/copy2clipboard": "^1.0.1",
    "@vavt/markdown-theme": "^5.0.2",
    "@vavt/util": "^2.1.2",
    "@vavt/v3-extension": "^5.0.0",
    "codemirror": "^6.0.2",
    "docx": "^9.7.0",
    "lucide-react": "^0.542.0",
    "markdown-it": "^14.0.0",
    "markdown-it-image-figures": "^2.1.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "mermaid": "^11.15.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/katex": "^0.16.7",
    "@types/multiparty": "^4.2.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vavt/vite-plugin-import-markdown": "^1.0.1",
    "@vitejs/plugin-react": "^5.0.2",
    "cropperjs": "^1.6.2",
    "echarts": "^6.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "globals": "^16.3.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.22",
    "less": "^4.4.1",
    "lint-staged": "^16.1.6",
    "multiparty": "^4.2.3",
    "prettier": "^3.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup-plugin-dts": "^6.3.0",
    "screenfull": "^6.0.2",
    "vite": "^7.1.5"
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": false
    }
  }
}
