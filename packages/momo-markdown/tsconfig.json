{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "useDefineForClassFields": true,
    "allowJs": false,
    "paths": {
      "@/*": ["./example/*"],
      "~~/*": ["./src/*"],
      "~/*": ["./src/components/MdEditor/*"]
    }
  },
  "include": ["example/**/*.ts", "example/**/*.tsx", "src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
